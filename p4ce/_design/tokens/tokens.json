    "md":   { "value": "12",  "unit": "pt" },
    "lg":   { "value": "16",  "unit": "pt" },
    "xl":   { "value": "20",  "unit": "pt" },
    "2xl":  { "value": "22",  "unit": "pt", "note": "Hero cards (V2 style)" },
    "3xl":  { "value": "24",  "unit": "pt", "note": "Full-bleed CTA button (V3 style)" },
    "full": { "value": "999", "unit": "pt" }
