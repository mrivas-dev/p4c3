{
  "_note": "Source of truth extracted from _design/screens/Home Dashboard.jsx",

  "color": {
    "bg":        { "oklch": "oklch(0.155 0.005 250)", "hex": "#121418", "usage": "Main app background" },
    "bgDeep":    { "oklch": "oklch(0.12  0.005 250)", "hex": "#0C0F13", "usage": "Deepest bg, tab bar (brutal variant)" },
    "surf":      { "oklch": "oklch(0.205 0.006 250)", "hex": "#1C2026", "usage": "Cards, hero cards, stat tiles" },
    "surfHi":    { "oklch": "oklch(0.245 0.006 250)", "hex": "#252B33", "usage": "Elevated elements, date badges" },
    "line":      { "oklch": "oklch(0.27  0.005 250)", "hex": "#363D47", "usage": "Borders, dividers, inactive bars" },
    "lineSoft":  { "oklch": "oklch(0.225 0.005 250)", "hex": "#272E38", "usage": "Subtle separators" },
    "text":      { "oklch": "oklch(0.97  0.005 90)",  "hex": "#F7F7F0", "usage": "Primary text, headings, values" },
    "textDim":   { "oklch": "oklch(0.80  0.005 90)",  "hex": "#C4C4B8", "usage": "Secondary text, supporting info" },
    "muted":     { "oklch": "oklch(0.55  0.010 250)", "hex": "#6B7280", "usage": "Metadata caps, timestamps" },
    "dim":       { "oklch": "oklch(0.40  0.010 250)", "hex": "#3F4550", "usage": "Inactive tab icons, de-emphasized" },
    "lime":      { "oklch": "oklch(0.86  0.20 124)",  "hex": "#D4F53C", "usage": "PRIMARY ACCENT — CTA, PRs, highlights" },
    "limeDeep":  { "oklch": "oklch(0.70  0.18 124)",  "hex": "#9EBF1A", "usage": "Pressed / active state of lime" },
    "limeInk":   { "oklch": "oklch(0.18  0.05 124)",  "hex": "#1A2605", "usage": "Text / icons ON lime background" },
    "red":       { "oklch": "oklch(0.70  0.18 25)",   "hex": "#E05A3A", "usage": "Danger, pain flags, low readiness" },
    "amber":     { "oklch": "oklch(0.82  0.16 78)",   "hex": "#F0C040", "usage": "Warning, medium readiness (5–6/10)" },
    "green":     { "oklch": "oklch(0.78  0.16 145)",  "hex": "#5DBF78", "usage": "Success, high readiness label" }
  },

  "typography": {
    "fontDisplay": { "family": "Antonio",       "fallback": "Geist, system-ui, sans-serif",       "usage": "Hero numbers, workout names, CTAs, stats" },
    "fontSans":    { "family": "Geist",          "fallback": "-apple-system, system-ui, sans-serif","usage": "Body text, labels, session names" },
    "fontMono":    { "family": "JetBrains Mono", "fallback": "ui-monospace, monospace",             "usage": "Metadata CAPS, dates, tags, letter-spaced labels" },

    "scale": {
      "heroWorkout":  { "font": "fontDisplay", "size": "68–76pt", "weight": 700, "letterSpacing": "-1.4 to -1.6" },
      "heroSub":      { "font": "fontDisplay", "size": "18–22pt", "weight": 500, "letterSpacing": "+0.4" },
      "statsLarge":   { "font": "fontDisplay", "size": "24–30pt", "weight": "600–700", "letterSpacing": "-0.5" },
      "ctaLabel":     { "font": "fontDisplay", "size": "26–30pt", "weight": 700, "letterSpacing": "+1.5" },
      "sectionDate":  { "font": "fontSans",    "size": "14–22pt", "weight": "500–600", "letterSpacing": "-0.3" },
      "sessionName":  { "font": "fontSans",    "size": "13–16pt", "weight": 500, "letterSpacing": "0" },
      "metadataCaps": { "font": "fontMono",    "size": "9–11pt",  "weight": "500–600", "letterSpacing": "+1.3 to +1.6", "textTransform": "uppercase" },
      "tagLabel":     { "font": "fontMono",    "size": "10pt",    "weight": 500, "letterSpacing": "+1.6", "textTransform": "uppercase" }
    }
  },

  "spacing": {
    "1":  { "value": "4",  "unit": "pt" },
    "2":  { "value": "8",  "unit": "pt" },
    "3":  { "value": "12", "unit": "pt" },
    "4":  { "value": "16", "unit": "pt" },
    "5":  { "value": "20", "unit": "pt" },
    "6":  { "value": "24", "unit": "pt" },
    "8":  { "value": "32", "unit": "pt" },
    "10": { "value": "40", "unit": "pt" },
    "12": { "value": "48", "unit": "pt" },
    "16": { "value": "64", "unit": "pt" }
  },

