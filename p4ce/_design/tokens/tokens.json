  "component": {
    "ctaHeight":    { "value": "76–88", "unit": "pt", "note": "START WORKOUT button" },
    "ctaRadius":    { "value": "20–22", "unit": "pt" },
    "cardRadius":   { "value": "16–22", "unit": "pt" },
    "heroCardPad":  { "value": "18",    "unit": "pt" },
    "screenHPad":   { "value": "16–24", "unit": "pt" },
    "statusBarTop": { "value": "54",    "unit": "pt" },
    "tabBarBottom": { "value": "96",    "unit": "pt", "note": "padding-bottom for content above tab bar" }
  },

  "screens": {
    "phone": { "width": 402, "height": 874, "unit": "pt", "model": "iPhone 17 Pro logical" }
  },

  "variants": {
    "V1_Notebook":       "Heavy typography, editorial journal feel. Large display font hero, monospace metadata, lime CTA only",
    "V2_Scoreboard":     "Dense + data-forward. Readiness ring top-right, stat tiles, compact last-session strip",
    "V3_FullBleedStart": "Workout name IS the start button. Stats stay tight up top. Brutalist one-tap commitment"
  }
